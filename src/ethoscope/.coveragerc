# Coverage configuration for the Ethoscope device package
[run]
source = ethoscope
omit =
    */tests/*
    */test_*
    */conftest.py
    */setup.py
    */venv/*
    */env/*
    */__pycache__/*
    */build/*
    */dist/*
    */.*
    */static/*
    */scripts/*
    # Hardware-specific code that cannot be tested in CI
    */utils/pi.py
    */hardware/interfaces/GPIO.py
    */hardware/interfaces/serial_wrapper.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

ignore_errors = True
show_missing = True
precision = 2
skip_covered = False
skip_empty = False

# Minimum coverage thresholds
# Lowered from 70% to account for hardware-specific code exclusions
# Progress: 38.45% (baseline) → 42.36% (SQLite tests) → 52.81% → 54.27% (triggers/cache/drawers)
# Incremental improvement plan: 54% → 58% → 62% → 65% → 70%
fail_under = 54

[html]
directory = htmlcov
title = Ethoscope Device Package Coverage Report

[xml]
output = coverage.xml
